"""
╔══════════════════════════════════════════════════════════════════════════════╗
║  HyperMorphic Corridor Codes (HCC)                                          ║
║  A State-Adaptive Invariant-Spanning Coding Primitive                       ║
╠══════════════════════════════════════════════════════════════════════════════╣
║                                                                              ║
║  WHAT IS NEW                                                                 ║
║  ────────────────────────────────────────────────────────────────────────    ║
║  HTC changes the coding geometry with local entropy, but still mostly asks: ║
║                                                                              ║
║      "Do I have at least k valid shards?"                                    ║
║                                                                              ║
║  HCC changes the decoding condition itself. It asks:                         ║
║                                                                              ║
║      "Do the surviving shards form a valid reconstruction corridor?"         ║
║                                                                              ║
║  A valid corridor requires:                                                   ║
║                                                                              ║
║    1. ALGEBRAIC CAPACITY                                                     ║
║       The product of selected CRT moduli must exceed chunk capacity.          ║
║                                                                              ║
║    2. GEOMETRIC LANE COVERAGE                                                ║
║       Surviving shards must span enough independent representation lanes.     ║
║                                                                              ║
║    3. CORRIDOR SCORE                                                         ║
║       The subset must have enough lane diversity, angular spread, and         ║
║       capacity margin for the current entropy/state regime.                  ║
║                                                                              ║
║  This means the threshold is no longer a fixed scalar k.                     ║
║                                                                              ║
║      k_t = f(H_t, geometry_span, capacity_margin, lane_diversity)            ║
║                                                                              ║
║  Same number of shards can pass or fail depending on their geometry.         ║
║                                                                              ║
║  FORMAL OBJECT                                                               ║
║  ────────────────────────────────────────────────────────────────────────    ║
║  HCC(n, D, W, E_levels, k_low, k_high) where:                                ║
║                                                                              ║
║    n          = total shards                                                  ║
║    D          = number of representation lanes / geometry axes               ║
║    W          = causal entropy window                                         ║
║    E_levels   = entropy quantization levels                                  ║
║    k_low      = minimum shard count in low-complexity states                 ║
║    k_high     = minimum shard count in high-complexity states                ║
║                                                                              ║
║  At each chunk position pos:                                                  ║
║                                                                              ║
║    H(pos)       = entropy of previous W decoded chunks                       ║
║    e(pos)       = quantized entropy state                                    ║
║    p_i(e)       = adaptive prime for shard i                                 ║
║    b_i(e)       = SafeGear base, gcd(b_i, p_i)=1                             ║
║    λ_i(pos,e)   = SHAKE128-derived position/state mixing term                ║
║                                                                              ║
║  Encoding:                                                                    ║
║                                                                              ║
║    r_i(pos) = (b_i(e) · C(pos) + λ_i(pos,e)) mod p_i(e)                     ║
║                                                                              ║
║  Decoding from selected corridor S:                                           ║
║                                                                              ║
║    c_i(pos) = (r_i(pos) - λ_i(pos,e)) · b_i(e)^(-1) mod p_i(e)              ║
║    C(pos)   = CRT({c_i mod p_i(e)} for i in S)                              ║
║                                                                              ║
║  Corridor validity:                                                           ║
║                                                                              ║
║    ∏_{i∈S} p_i(e) > 256^chunk_bytes                                          ║
║    lanes(S) ≥ required_lanes(e)                                              ║
║    |S|      ≥ required_shards(e)                                             ║
║    score(S,e) ≥ required_score(e)                                            ║
║                                                                              ║
║  IMPORTANT                                                                    ║
║  ────────────────────────────────────────────────────────────────────────    ║
║  This is a research prototype, not production cryptography. The HMAC layer   ║
║  is for integrity/testing, not a full security model.                        ║
╚══════════════════════════════════════════════════════════════════════════════╝
"""

import math
import os
import time
import copy
import hmac
import hashlib
from dataclasses import dataclass
from functools import reduce
from itertools import combinations
from collections import Counter, defaultdict
from typing import List, Tuple, Dict, Optional


# ═══════════════════════════════════════════════════════════════════════
# SECTION 1 — MATHEMATICAL FOUNDATION
# ═══════════════════════════════════════════════════════════════════════

def _egcd(a: int, b: int):
    if a == 0:
        return b, 0, 1
    g, x, y = _egcd(b % a, a)
    return g, y - (b // a) * x, x


def modinv(a: int, m: int) -> int:
    g, x, _ = _egcd(a % m, m)
    if g != 1:
        raise ArithmeticError(f"No inverse: gcd({a},{m})={g}")
    return x % m


def crt(residues: List[int], moduli: List[int]) -> int:
    """
    Chinese Remainder Theorem reconstruction.
    Moduli must be pairwise coprime.
    """
    M = reduce(lambda a, b: a * b, moduli, 1)
    x = 0

    for r, m in zip(residues, moduli):
        Mi = M // m
        x += r * Mi * modinv(Mi % m, m)

    return x % M


def is_prime(n: int) -> bool:
    if n < 2:
        return False
    if n < 4:
        return True
    if n % 2 == 0 or n % 3 == 0:
        return False

    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6

    return True


def primes_from(start: int, count: int) -> List[int]:
    out = []
    x = start if start % 2 else start + 1

    while len(out) < count:
        if is_prime(x):
            out.append(x)
        x += 2

    return out


def safe_base(m: int) -> int:
    """
    SafeGear-style base:
    start near log2(m), then increment until gcd(b,m)=1.
    """
    b = math.floor(math.log2(max(m, 2))) + 1
    while math.gcd(b, m) != 1:
        b += 1
    return b


def shannon_entropy(data: bytes) -> float:
    if not data:
        return 0.0

    n = len(data)
    counts = Counter(data)

    return -sum((c / n) * math.log2(c / n) for c in counts.values())


def shake128_int(seed: bytes, byte_len: int) -> int:
    return int.from_bytes(hashlib.shake_128(seed).digest(byte_len), "big")


# ═══════════════════════════════════════════════════════════════════════
# SECTION 2 — CAUSAL ENTROPY WINDOW
# ═══════════════════════════════════════════════════════════════════════

class CausalEntropyWindow:
    """
    Uses only previously decoded chunks.
    This is critical: encoder and decoder reproduce the same state path.
    """

    def __init__(self, W: int = 8, chunk_bytes: int = 5):
        self.W = W
        self.chunk_bytes = chunk_bytes
        self.buffer = []

    def push(self, C: int):
        self.buffer.append(C)
        if len(self.buffer) > self.W:
            self.buffer.pop(0)

    def estimate(self) -> float:
        if not self.buffer:
            return 0.0

        data = b"".join(
            int(c).to_bytes(self.chunk_bytes, "big")
            for c in self.buffer
        )
        return shannon_entropy(data)

    def reset(self):
        self.buffer = []


# ═══════════════════════════════════════════════════════════════════════
# SECTION 3 — SHARD STRUCTURE
# ═══════════════════════════════════════════════════════════════════════

@dataclass
class HCCShard:
    index: int
    lane: int
    phase: int
    residues: List[int]
    data_len: int
    data_hmac: bytes
    shard_hmac: bytes
    n: int
    geometry_dim: int
    W: int
    E_levels: int
    chunk_bytes: int

    def payload_bytes(self) -> bytes:
        head = (
            f"HCC|i={self.index}|lane={self.lane}|phase={self.phase}|"
            f"len={self.data_len}|n={self.n}|D={self.geometry_dim}|"
            f"W={self.W}|E={self.E_levels}|cb={self.chunk_bytes}|"
        ).encode()

        body = b"".join(
            int(r).to_bytes(8, "big", signed=False)
            for r in self.residues
        )

        return head + body

    def compute_hmac(self, key: bytes) -> bytes:
        return hmac.new(key, self.payload_bytes(), hashlib.sha256).digest()

    def verify_hmac(self, key: bytes) -> bool:
        return hmac.compare_digest(self.shard_hmac, self.compute_hmac(key))

    def __repr__(self):
        return (
            f"HCCShard(i={self.index}, lane={self.lane}, "
            f"phase={self.phase}, chunks={len(self.residues)})"
        )


# ═══════════════════════════════════════════════════════════════════════
# SECTION 4 — PRIME TOPOLOGY
# ═══════════════════════════════════════════════════════════════════════

def build_prime_table(n: int, E_levels: int, start: int = 2003) -> List[List[int]]:
    """
    PRIME_TABLE[i][e] gives shard i's prime at entropy level e.

    Larger entropy levels get larger primes.
    All entries are unique.
    """
    pool = primes_from(start, n * E_levels + 100)

    table = []
    for i in range(n):
        row = []
        for e in range(E_levels):
            row.append(pool[i * E_levels + e])
        table.append(row)

    return table


# ═══════════════════════════════════════════════════════════════════════
# SECTION 5 — HYPERMORPHIC CORRIDOR CODE
# ═══════════════════════════════════════════════════════════════════════

class HyperMorphicCorridorCode:
    """
    HyperMorphic Corridor Code.

    Difference from fixed threshold coding:
      Fixed threshold code:
          recoverable iff |S| >= k

      Corridor code:
          recoverable iff S spans a valid reconstruction corridor.

    Corridor validity depends on:
      - algebraic capacity
      - geometry lane coverage
      - lane entropy
      - angular spread
      - local causal entropy state
    """

    def __init__(
        self,
        n: int = 12,
        geometry_dim: int = 4,
        W: int = 8,
        E_levels: int = 9,
        low_shards: int = 4,
        high_shards: int = 6,
        auth_key: bytes = b"HCC-demo-key-v1",
    ):
        assert n >= geometry_dim >= 2
        assert 2 <= low_shards <= high_shards <= n

        self.n = n
        self.D = geometry_dim
        self.W = W
        self.E_levels = E_levels
        self.low_shards = low_shards
        self.high_shards = high_shards
        self.auth_key = auth_key

        # Each shard sits on a representation lane.
        # Round-robin assignment gives balanced geometric axes.
        self.lanes = [i % self.D for i in range(n)]
        self.phases = [i // self.D for i in range(n)]

        self.prime_table = build_prime_table(n, E_levels)

        # Conservative chunk size:
        # even the lowest entropy state with low_shards must have enough product.
        primes0 = sorted(self.prime_table[i][0] for i in range(n))
        prod_low = reduce(lambda a, b: a * b, primes0[:self.low_shards], 1)

        self.chunk_bytes = max(1, int(math.log(prod_low - 1, 256)))
        self.max_chunk = 256 ** self.chunk_bytes - 1

        if prod_low <= self.max_chunk:
            raise ValueError("Prime table too small for chosen chunk size")

        self.base_table = [
            [safe_base(self.prime_table[i][e]) for e in range(E_levels)]
            for i in range(n)
        ]

        self.inv_cache = {}
        for i in range(n):
            for e in range(E_levels):
                p = self.prime_table[i][e]
                b = self.base_table[i][e]
                self.inv_cache[(b, p)] = modinv(b, p)

        self._subset_cache = {}

        self._verify_invariants()

    # ──────────────────────────────────────────────────────────────────
    # Invariants
    # ──────────────────────────────────────────────────────────────────

    def _verify_invariants(self):
        flat = [p for row in self.prime_table for p in row]

        assert all(is_prime(p) for p in flat), "Non-prime in prime table"
        assert len(set(flat)) == len(flat), "Duplicate primes"

        for e in range(self.E_levels):
            assert len(set(self.prime_table[i][e] for i in range(self.n))) == self.n

        for i in range(self.n):
            for e in range(self.E_levels):
                assert math.gcd(self.base_table[i][e], self.prime_table[i][e]) == 1

        for e in range(self.E_levels):
            primes = sorted(self.prime_table[i][e] for i in range(self.n))
            prod = reduce(lambda a, b: a * b, primes[:self.low_shards], 1)
            assert prod > self.max_chunk

    # ──────────────────────────────────────────────────────────────────
    # State and parameters
    # ──────────────────────────────────────────────────────────────────

    def _quantize_entropy(self, H: float) -> int:
        """
        H in [0,8] bits/byte → entropy level.
        """
        return min(int((H / 8.0) * self.E_levels), self.E_levels - 1)

    def _required_shards(self, e: int) -> int:
        """
        State-dependent shard floor.
        Low entropy can recover with fewer shards.
        High entropy demands stronger corridor evidence.
        """
        if self.E_levels <= 1:
            return self.low_shards

        return self.low_shards + round(
            (self.high_shards - self.low_shards) * e / (self.E_levels - 1)
        )

    def _required_lanes(self, e: int) -> int:
        """
        Low entropy: at least 2 geometry axes.
        High entropy: full lane span.
        """
        if self.E_levels <= 1:
            return min(2, self.D)

        return min(
            self.D,
            2 + round((self.D - 2) * e / (self.E_levels - 1))
        )

    def _required_score(self, e: int) -> float:
        """
        State-dependent corridor score threshold.
        """
        return 0.36 + 0.26 * (e / max(1, self.E_levels - 1))

    def _lambda(self, i: int, pos: int, prime: int, e: int) -> int:
        """
        Position/state-dependent mixing term.
        """
        seed = (
            b"HCC-lambda|"
            + i.to_bytes(2, "big")
            + pos.to_bytes(6, "big")
            + e.to_bytes(2, "big")
        )
        return shake128_int(seed, 8) % prime

    def _params_for(self, i: int, e: int):
        p = self.prime_table[i][e]
        b = self.base_table[i][e]
        inv = self.inv_cache[(b, p)]
        return p, b, inv

    # ──────────────────────────────────────────────────────────────────
    # Byte chunking
    # ──────────────────────────────────────────────────────────────────

    def _pad(self, data: bytes) -> bytes:
        pad = (-len(data)) % self.chunk_bytes
        return data + bytes(pad)

    def _to_chunks(self, data: bytes) -> List[int]:
        cb = self.chunk_bytes
        return [
            int.from_bytes(data[i:i + cb], "big")
            for i in range(0, len(data), cb)
        ]

    def _from_chunks(self, chunks: List[int]) -> bytes:
        return b"".join(
            int(c).to_bytes(self.chunk_bytes, "big")
            for c in chunks
        )

    def _data_hmac(self, data: bytes) -> bytes:
        return hmac.new(
            self.auth_key,
            b"HCC-data|" + data,
            hashlib.sha256
        ).digest()

    # ──────────────────────────────────────────────────────────────────
    # Encode
    # ──────────────────────────────────────────────────────────────────

    def encode(self, data: bytes) -> List[HCCShard]:
        padded = self._pad(data)
        chunks = self._to_chunks(padded)

        residue_lists = [[] for _ in range(self.n)]
        window = CausalEntropyWindow(self.W, self.chunk_bytes)

        for pos, C in enumerate(chunks):
            H = window.estimate()
            e = self._quantize_entropy(H)

            for i in range(self.n):
                p, b, _ = self._params_for(i, e)
                lam = self._lambda(i, pos, p, e)
                r = (b * C + lam) % p
                residue_lists[i].append(r)

            window.push(C)

        data_hmac = self._data_hmac(data)

        shards = []
        for i in range(self.n):
            s = HCCShard(
                index=self.lanes.index(self.lanes[i]) if False else i,
                lane=self.lanes[i],
                phase=self.phases[i],
                residues=residue_lists[i],
                data_len=len(data),
                data_hmac=data_hmac,
                shard_hmac=b"",
                n=self.n,
                geometry_dim=self.D,
                W=self.W,
                E_levels=self.E_levels,
                chunk_bytes=self.chunk_bytes,
            )
            s.shard_hmac = s.compute_hmac(self.auth_key)
            shards.append(s)

        return shards

    # ──────────────────────────────────────────────────────────────────
    # Corridor metrics
    # ──────────────────────────────────────────────────────────────────

    def corridor_metrics(self, indices: List[int], e: int) -> Dict[str, float]:
        idx = tuple(sorted(indices))
        lanes = [self.lanes[i] for i in idx]
        lane_counts = Counter(lanes)

        lane_coverage = len(lane_counts) / self.D

        n = len(lanes)
        if n == 0:
            lane_entropy = 0.0
            angular_spread = 0.0
        else:
            lane_entropy = -sum(
                (c / n) * math.log2(c / n)
                for c in lane_counts.values()
            ) / math.log2(self.D)

            vx = 0.0
            vy = 0.0
            for lane in lanes:
                theta = 2 * math.pi * lane / self.D
                vx += math.cos(theta)
                vy += math.sin(theta)

            resultant = math.sqrt(vx * vx + vy * vy) / n
            angular_spread = 1.0 - resultant

        moduli = [self.prime_table[i][e] for i in idx]
        product = reduce(lambda a, b: a * b, moduli, 1)

        capacity_bytes = math.log(product, 256) if product > 0 else 0.0
        capacity_margin = capacity_bytes - self.chunk_bytes
        capacity_score = min(
            1.0,
            max(0.0, capacity_margin / max(1, self.chunk_bytes))
        )

        score = (
            0.38 * lane_coverage
            + 0.30 * lane_entropy
            + 0.22 * angular_spread
            + 0.10 * capacity_score
        )

        return {
            "size": len(idx),
            "lanes": len(lane_counts),
            "lane_coverage": lane_coverage,
            "lane_entropy": lane_entropy,
            "angular_spread": angular_spread,
            "product": product,
            "capacity_bytes": capacity_bytes,
            "capacity_margin": capacity_margin,
            "capacity_score": capacity_score,
            "corridor_score": score,
            "required_shards": self._required_shards(e),
            "required_lanes": self._required_lanes(e),
            "required_score": self._required_score(e),
        }

    def corridor_valid(self, indices: List[int], e: int) -> bool:
        m = self.corridor_metrics(indices, e)

        return (
            m["size"] >= m["required_shards"]
            and m["lanes"] >= m["required_lanes"]
            and m["product"] > self.max_chunk
            and m["corridor_score"] >= m["required_score"]
        )

    # ──────────────────────────────────────────────────────────────────
    # Shard validation and subset selection
    # ──────────────────────────────────────────────────────────────────

    def _valid_shards(
        self,
        shards: List[Optional[HCCShard]],
        require_hmac: bool = True,
    ) -> List[HCCShard]:

        out = []
        seen = set()

        for s in shards:
            if s is None or not isinstance(s, HCCShard):
                continue

            if s.index in seen:
                continue

            if require_hmac and not s.verify_hmac(self.auth_key):
                continue

            if (
                s.n != self.n
                or s.geometry_dim != self.D
                or s.W != self.W
                or s.E_levels != self.E_levels
                or s.chunk_bytes != self.chunk_bytes
            ):
                continue

            out.append(s)
            seen.add(s.index)

        return sorted(out, key=lambda s: s.index)

    def _select_corridor_subset(self, available: List[HCCShard], e: int) -> List[HCCShard]:
        available = sorted(available, key=lambda s: s.index)
        ids = tuple(s.index for s in available)

        key = (ids, e)
        if key in self._subset_cache:
            selected_ids = self._subset_cache[key]
            smap = {s.index: s for s in available}
            return [smap[i] for i in selected_ids]

        # Fast path: all surviving shards form a corridor.
        all_idx = list(ids)
        if self.corridor_valid(all_idx, e):
            self._subset_cache[key] = tuple(all_idx)
            return available

        # Search for the smallest valid corridor.
        req = self._required_shards(e)
        best_tuple = None
        best_value = None

        for r in range(req, len(available) + 1):
            for combo in combinations(ids, r):
                if self.corridor_valid(list(combo), e):
                    metrics = self.corridor_metrics(list(combo), e)
                    value = (
                        metrics["corridor_score"],
                        metrics["capacity_margin"],
                    )

                    if best_value is None or value > best_value:
                        best_value = value
                        best_tuple = combo

            if best_tuple is not None:
                break

        if best_tuple is None:
            raise ValueError(
                f"No valid reconstruction corridor at entropy level {e}; "
                f"available={list(ids)}"
            )

        self._subset_cache[key] = tuple(best_tuple)
        smap = {s.index: s for s in available}

        return [smap[i] for i in best_tuple]

    # ──────────────────────────────────────────────────────────────────
    # Decode
    # ──────────────────────────────────────────────────────────────────

    def _reconstruct(
        self,
        available: List[HCCShard],
        data_len: int,
        collect_certificate: bool = False,
    ):
        if not available:
            raise ValueError("No shards")

        n_chunks = len(available[0].residues)
        for s in available:
            if len(s.residues) != n_chunks:
                raise ValueError("Mismatched shard lengths")

        window = CausalEntropyWindow(self.W, self.chunk_bytes)
        chunks = []

        cert = {
            "positions": n_chunks,
            "entropy_levels": [],
            "subset_sizes": [],
            "lane_counts": [],
            "corridor_scores": [],
            "capacity_margins": [],
            "selected_subsets_sample": [],
        }

        for pos in range(n_chunks):
            H = window.estimate()
            e = self._quantize_entropy(H)

            selected = self._select_corridor_subset(available, e)
            indices = [s.index for s in selected]
            metrics = self.corridor_metrics(indices, e)

            residues = []
            moduli = []

            for s in selected:
                p, b, inv_b = self._params_for(s.index, e)
                lam = self._lambda(s.index, pos, p, e)
                r = s.residues[pos]

                c = ((r - lam) * inv_b) % p

                residues.append(c)
                moduli.append(p)

            C = crt(residues, moduli)

            if C > self.max_chunk:
                raise ValueError("CRT output outside chunk range")

            chunks.append(C)
            window.push(C)

            if collect_certificate:
                cert["entropy_levels"].append(e)
                cert["subset_sizes"].append(len(indices))
                cert["lane_counts"].append(metrics["lanes"])
                cert["corridor_scores"].append(metrics["corridor_score"])
                cert["capacity_margins"].append(metrics["capacity_margin"])

                if len(cert["selected_subsets_sample"]) < 12:
                    cert["selected_subsets_sample"].append({
                        "pos": pos,
                        "entropy_level": e,
                        "indices": indices,
                        "lanes": [self.lanes[i] for i in indices],
                        "score": round(metrics["corridor_score"], 4),
                        "capacity_margin_bytes": round(metrics["capacity_margin"], 4),
                    })

        raw = self._from_chunks(chunks)
        data = raw[:data_len]

        if not hmac.compare_digest(self._data_hmac(data), available[0].data_hmac):
            raise ValueError("Data HMAC failed: corridor did not reconstruct original data")

        if not collect_certificate:
            return data

        cert["entropy_level_dist"] = dict(Counter(cert["entropy_levels"]))
        cert["subset_size_dist"] = dict(Counter(cert["subset_sizes"]))
        cert["lane_count_dist"] = dict(Counter(cert["lane_counts"]))
        cert["min_corridor_score"] = round(min(cert["corridor_scores"]), 5)
        cert["min_capacity_margin_bytes"] = round(min(cert["capacity_margins"]), 5)
        cert["max_required_shards_seen"] = max(
            self._required_shards(e) for e in cert["entropy_levels"]
        )
        cert["max_required_lanes_seen"] = max(
            self._required_lanes(e) for e in cert["entropy_levels"]
        )

        return data, cert

    def decode(self, shards: List[Optional[HCCShard]]) -> bytes:
        valid = self._valid_shards(shards, require_hmac=True)

        if len(valid) < self.low_shards:
            raise ValueError(
                f"Need at least {self.low_shards} valid shards before corridor search; "
                f"have {len(valid)}"
            )

        return self._reconstruct(valid, valid[0].data_len, collect_certificate=False)

    def decode_with_certificate(self, shards: List[Optional[HCCShard]]) -> Tuple[bytes, Dict]:
        valid = self._valid_shards(shards, require_hmac=True)

        if len(valid) < self.low_shards:
            raise ValueError(
                f"Need at least {self.low_shards} valid shards before corridor search; "
                f"have {len(valid)}"
            )

        return self._reconstruct(valid, valid[0].data_len, collect_certificate=True)

    # ──────────────────────────────────────────────────────────────────
    # Byzantine consensus decoding
    # ──────────────────────────────────────────────────────────────────

    def decode_byzantine(
        self,
        shards: List[Optional[HCCShard]],
        max_subset_size: int = None,
    ):
        """
        Byzantine-tolerant consensus decode.

        It tries many corridor-valid subsets and chooses the majority
        reconstruction. This is expensive but useful for proof/demo.
        """
        valid = self._valid_shards(shards, require_hmac=False)

        if len(valid) < self.low_shards:
            raise ValueError("Not enough physical shards")

        if max_subset_size is None:
            max_subset_size = min(self.n, self.high_shards + 1)

        candidates = defaultdict(int)
        data_for_hash = {}
        good_combos_by_hash = defaultdict(list)

        ids = [s.index for s in valid]
        smap = {s.index: s for s in valid}

        for r in range(self.low_shards, min(max_subset_size, len(valid)) + 1):
            for combo in combinations(ids, r):
                subset = [smap[i] for i in combo]

                try:
                    data = self._reconstruct(
                        subset,
                        subset[0].data_len,
                        collect_certificate=False,
                    )
                    dh = hashlib.sha256(data).digest()

                    candidates[dh] += 1
                    data_for_hash[dh] = data
                    good_combos_by_hash[dh].append(combo)

                except Exception:
                    pass

        if not candidates:
            raise ValueError("No consensus reconstruction found")

        best = max(candidates, key=candidates.get)
        data = data_for_hash[best]
        combos = good_combos_by_hash[best]

        participation = Counter(i for combo in combos for i in combo)

        good = sorted(i for i, c in participation.items() if c > 0)
        bad = sorted(
            i for i in ids
            if i not in good or not smap[i].verify_hmac(self.auth_key)
        )

        report = {
            "consensus_votes": candidates[best],
            "candidate_count": len(candidates),
            "tested_successful_combos": sum(candidates.values()),
            "good_shards": good,
            "bad_or_suspicious_shards": bad,
            "participation": dict(participation),
        }

        return data, report

    # ──────────────────────────────────────────────────────────────────
    # Analysis
    # ──────────────────────────────────────────────────────────────────

    def analyse(self, data: bytes = None) -> Dict:
        info = {
            "n": self.n,
            "geometry_dim": self.D,
            "W": self.W,
            "E_levels": self.E_levels,
            "low_shards": self.low_shards,
            "high_shards": self.high_shards,
            "chunk_bytes": self.chunk_bytes,
            "max_chunk": self.max_chunk,
            "lanes": {i: self.lanes[i] for i in range(self.n)},
        }

        levels = []
        for e in range(self.E_levels):
            primes = sorted(self.prime_table[i][e] for i in range(self.n))
            req = self._required_shards(e)
            prod = reduce(lambda a, b: a * b, primes[:req], 1)

            levels.append({
                "level": e,
                "required_shards": req,
                "required_lanes": self._required_lanes(e),
                "required_score": round(self._required_score(e), 4),
                "min_prime": primes[0],
                "max_prime": primes[-1],
                "capacity_bytes": round(math.log(prod, 256), 4),
            })

        info["level_stats"] = levels

        if data is not None:
            padded = self._pad(data)
            chunks = self._to_chunks(padded)
            window = CausalEntropyWindow(self.W, self.chunk_bytes)

            trace = []
            for C in chunks:
                H = window.estimate()
                e = self._quantize_entropy(H)
                trace.append(e)
                window.push(C)

            info["data_entropy_level_dist"] = dict(Counter(trace))

        return info


