# SECTION 6 — TEST SUITE
# ═══════════════════════════════════════════════════════════════════════

def run_tests():
    print("╔══════════════════════════════════════════════════════════════════════╗")
    print("║  HyperMorphic Corridor Code — Test Suite                            ║")
    print("╚══════════════════════════════════════════════════════════════════════╝")

    hcc = HyperMorphicCorridorCode()
    results = []

    def check(name, condition, note=""):
        results.append(bool(condition))
        icon = "✅" if condition else "❌"
        print(f"  {icon} {name:<65} {note}")

    def section(title):
        print("\n" + "─" * 78)
        print(" ", title)
        print("─" * 78)

    # 1. Basic roundtrip
    section("1. BASIC ROUNDTRIP")

    test_cases = [
        ("short string", b"HyperMorphic Corridor Code"),
        ("single byte", b"x"),
        ("all zeros", bytes(512)),
        ("full range", bytes(range(256)) * 2),
        ("random 2KB", os.urandom(2048)),
        ("repeated phrase", b"corridor-code-" * 200),
    ]

    for name, data in test_cases:
        shards = hcc.encode(data)
        recovered = hcc.decode(shards)
        check(f"Roundtrip: {name}", recovered == data, f"len={len(data)}")

    # 2. Corridor property
    section("2. VARIABLE CORRIDOR PROPERTY")

    low = bytes([7]) * 512
    shards_low = hcc.encode(low)

    low_ids = [0, 1, 4, 5]  # 4 shards, lanes 0/1 only
    low_subset = [shards_low[i] if i in low_ids else None for i in range(hcc.n)]

    try:
        recovered = hcc.decode(low_subset)
        check(
            "Low entropy: 4 shards over 2 lanes recover",
            recovered == low,
            f"ids={low_ids}, lanes={[hcc.lanes[i] for i in low_ids]}",
        )
    except Exception as ex:
        check("Low entropy: 4 shards over 2 lanes recover", False, str(ex))

    high = os.urandom(2048)
    shards_high = hcc.encode(high)

    good_ids = [0, 1, 2, 3, 4, 5]      # 6 shards, all 4 lanes
    bad_ids = [0, 1, 4, 5, 8, 9]       # 6 shards, only lanes 0/1

    for label, ids, should_pass in [
        ("High entropy: 6 shards with full geometry span recover", good_ids, True),
        ("High entropy: 6 shards with poor geometry span fail", bad_ids, False),
    ]:
        subset = [shards_high[i] if i in ids else None for i in range(hcc.n)]

        try:
            recovered = hcc.decode(subset)
            ok = recovered == high
            check(
                label,
                ok == should_pass,
                f"ids={ids}, lanes={[hcc.lanes[i] for i in ids]}, recovered={ok}",
            )

        except Exception as ex:
            check(
                label,
                should_pass is False,
                f"ids={ids}, lanes={[hcc.lanes[i] for i in ids]}, fail={str(ex)[:70]}",
            )

    # 3. Same count, different geometry
    section("3. SAME SHARD COUNT, DIFFERENT GEOMETRY")

    m_good = hcc.corridor_metrics(good_ids, e=hcc.E_levels - 1)
    m_bad = hcc.corridor_metrics(bad_ids, e=hcc.E_levels - 1)

    check(
        "Good 6-shard subset has enough lanes",
        m_good["lanes"] >= m_good["required_lanes"],
        f"lanes={m_good['lanes']}, required={m_good['required_lanes']}",
    )

    check(
        "Bad 6-shard subset fails lane requirement",
        m_bad["lanes"] < m_bad["required_lanes"],
        f"lanes={m_bad['lanes']}, required={m_bad['required_lanes']}",
    )

    check(
        "Good corridor score exceeds bad corridor score",
        m_good["corridor_score"] > m_bad["corridor_score"],
        f"good={m_good['corridor_score']:.4f}, bad={m_bad['corridor_score']:.4f}",
    )

    # 4. Certificate
    section("4. CORRIDOR CERTIFICATE")

    data = os.urandom(1024)
    shards = hcc.encode(data)

    # Erase several shards, leaving a recoverable corridor.
    for i in [6, 7, 10]:
        shards[i] = None

    recovered, cert = hcc.decode_with_certificate(shards)

    check("Decode with certificate", recovered == data)
    check("Certificate has entropy-level distribution", "entropy_level_dist" in cert)
    check("Certificate has subset-size distribution", "subset_size_dist" in cert)
    check("Certificate records selected subset samples", len(cert["selected_subsets_sample"]) > 0)

    print("\n  Certificate summary:")
    print(f"    entropy_level_dist:        {cert['entropy_level_dist']}")
    print(f"    subset_size_dist:          {cert['subset_size_dist']}")
    print(f"    lane_count_dist:           {cert['lane_count_dist']}")
    print(f"    min_corridor_score:        {cert['min_corridor_score']}")
    print(f"    min_capacity_margin_bytes: {cert['min_capacity_margin_bytes']}")
    print(f"    sample:                    {cert['selected_subsets_sample'][:2]}")

    # 5. HMAC integrity
    section("5. INTEGRITY AND BYZANTINE TESTS")

    msg = b"Byzantine corridor test payload" * 30
    shards = hcc.encode(msg)

    tampered = [copy.deepcopy(s) for s in shards]
    tampered[0].residues[0] ^= 1

    valid_after = hcc._valid_shards(tampered, require_hmac=True)
    check(
        "Shard HMAC rejects tampered shard",
        0 not in [s.index for s in valid_after],
        f"{len(valid_after)}/{hcc.n} pass HMAC",
    )

    recovered, report = hcc.decode_byzantine(tampered)

    check("Byzantine consensus recovers with 1 corrupted shard", recovered == msg)
    check(
        "Byzantine report flags suspicious shard",
        0 in report["bad_or_suspicious_shards"],
        f"bad={report['bad_or_suspicious_shards']}",
    )

    # 6. Erasure stress
    section("6. ERASURE STRESS")

    data = os.urandom(2048)
    shards = hcc.encode(data)

    # Keep one full good corridor and erase the rest.
    keep = [0, 1, 2, 3, 4, 5]
    erased = [shards[i] if i in keep else None for i in range(hcc.n)]

    try:
        recovered = hcc.decode(erased)
        check(
            "Recover from exactly one 6-shard full-span corridor",
            recovered == data,
            f"keep={keep}, lanes={[hcc.lanes[i] for i in keep]}",
        )
    except Exception as ex:
        check("Recover from exactly one 6-shard full-span corridor", False, str(ex))

    # 7. Results
    section("SUMMARY")

    passed = sum(results)
    total = len(results)

    print(f"  RESULTS: {passed}/{total} passed")

    if passed == total:
        print("  ✅ ALL PASS — HCC primitive validated")
    else:
        print(f"  ❌ {total - passed} failures")

    return passed == total


